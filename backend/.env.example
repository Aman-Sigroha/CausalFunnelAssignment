PORT=5000

# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/causalfunnel-analytics

# MongoDB Atlas (SRV):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/causalfunnel-analytics?appName=Cluster0

# MongoDB Atlas (standard — use if SRV DNS fails on Windows):
# MONGODB_URI=mongodb://<user>:<password>@<shard-host>:27017,<shard-host>:27017,<shard-host>:27017/causalfunnel-analytics?ssl=true&authSource=admin&retryWrites=true&w=majority
